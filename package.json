{
  "name": "unilu-md",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "dev": "slidev slides.md --port 3030 --open",
    "dev:host": "slidev slides.md --remote=unilu-codespace --bind 0.0.0.0 --port 3030",
    "build": "slidev build slides.md",
    "build:public": "node scripts/build-pages.mjs",
    "export": "slidev export slides.md --output presentation.pdf",
    "export:clicks": "slidev export slides.md --with-clicks --output presentation-with-clicks.pdf",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:md": "markdownlint-cli2",
    "check:deck": "node scripts/check-deck.mjs slides.md",
    "qa:visual": "node scripts/visual-qa.mjs",
    "test": "vitest run",
    "check": "pnpm format:check && pnpm lint:md && pnpm check:deck && pnpm test && pnpm build && pnpm qa:visual"
  },
  "devDependencies": {
    "@iconify-json/lucide": "1.2.117",
    "@slidev/cli": "52.17.0",
    "@slidev/client": "52.17.0",
    "@slidev/parser": "52.17.0",
    "@slidev/types": "52.17.0",
    "markdownlint-cli2": "0.23.0",
    "pixelmatch": "7.2.0",
    "playwright-chromium": "1.61.1",
    "pngjs": "7.0.0",
    "prettier": "3.9.5",
    "prettier-plugin-slidev": "1.0.5",
    "slidev-theme-unilu": "workspace:*",
    "typescript": "7.0.2",
    "vitest": "4.1.10",
    "vue": "3.5.39"
  }
}
