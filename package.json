{
  "name": "unilu-md",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:raw": "node scripts/run-slidev.mjs slides.md --port 3030 --open",
    "dev:host": "node scripts/dev.mjs --remote --no-open",
    "free-ports": "node scripts/dev.mjs --free-only",
    "build": "node scripts/run-slidev.mjs build slides.md",
    "build:local": "node scripts/workflow.mjs build",
    "build:public": "node scripts/build-pages.mjs",
    "export": "node scripts/run-slidev.mjs export slides.md --output presentation.pdf",
    "export:clicks": "node scripts/run-slidev.mjs export slides.md --with-clicks --output presentation-with-clicks.pdf",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:md": "markdownlint-cli2",
    "check:deck": "node scripts/check-deck.mjs slides.md",
    "qa:visual": "node scripts/visual-qa.mjs",
    "qa:visual:dist": "node scripts/visual-qa.mjs --dist",
    "test": "vitest run",
    "scratchpad:init": "node scripts/scratchpad.mjs init",
    "scratchpad:check": "node scripts/scratchpad.mjs check",
    "scratchpad:handoff": "node scripts/scratchpad.mjs handoff",
    "update:local": "node scripts/workflow.mjs content",
    "update:visual": "node scripts/workflow.mjs visual",
    "check:full": "node scripts/workflow.mjs full",
    "check": "pnpm check:full",
    "timings": "node scripts/workflow.mjs report"
  },
  "devDependencies": {
    "@iconify-json/lucide": "1.2.117",
    "@slidev/cli": "52.17.0",
    "@slidev/client": "52.17.0",
    "@slidev/parser": "52.17.0",
    "@slidev/types": "52.17.0",
    "markdownlint-cli2": "0.23.0",
    "pixelmatch": "7.2.0",
    "playwright-chromium": "1.61.1",
    "pngjs": "7.0.0",
    "prettier": "3.9.5",
    "prettier-plugin-slidev": "1.0.5",
    "slidev-theme-unilu": "workspace:*",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "vue": "3.5.39"
  }
}
